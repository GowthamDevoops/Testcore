@model IEnumerable<CartItem>

@{
    double total = 0;
    double itemtotal = 0;
}

<h2 class="my-4">Shopping Cart</h2>
@* <partial name="_notification" /> *@
<table class="table table-bordered shadow">
    <thead class="table-dark">
        <tr>
            <th>Image</th>
            <th>Product</th>
            <th>Description</th>
            <th>Quantity</th>
            <th>Price</th>
            <th>Total</th>
            
            <th style="width:150px">Actions</th>
        </tr>
    </thead>
    <tbody>

        @foreach(var item in Model)
        {
            itemtotal = item.Quantity * Convert.ToDouble(item.Product.Price);
            total += itemtotal;
            <tr>
                <td>
                <img src="@(item.Product.Imagepath ?? "https://placehold.co/500X600/png")" class="image-thumbnail" />
                </td>
                <td>
                    @item.Product.Name
                </td>
                <td>
                    <small>@Html.Raw(item.Product.Description)</small>
                </td>
                <td>
                    @item.Quantity
                </td>
                <td>
                    @item.Product.Price.ToString("0.00")
                </td>
                <td>@itemtotal.ToString("0.00")</td>
                <td>
                    <div class="btn-group">
                        <a  asp-action="plus" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-plus"></i></a>
                        <a asp-action="minus" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning"><i class="bi bi-dash"></i></a>
                        <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                    </div>
                </td>
            </tr>
        }

    </tbody>
    <tfoot>
        <tr class="table-secondary">
            <td colspan="5" class="text-end">Grand Total</td>
            <td colspan="2" class="fw-bold">@total.ToString("0.00")</td>
        </tr>
    </tfoot>
</table>

<div class="text-center">
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Continue Shopping</a>
    <a asp-controller="summary" asp-action="Index" class="btn btn-dark text-uppercase">Procced to Summary</a>
</div>