@model Product

<div class="card border-0">
    <div class="card-header ms-0 text-white" style="background-color:darkcyan">
        <h1 class="p-2 text-center">Edit Product</h1>
    </div>
    <div class="card-body mt-3">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="" />
                <label class="mb-2 text-muted">Name</label>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Description" class="form-control" placeholder="" />
                <label class="mb-2 text-muted">Description</label>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Price" class="form-control" placeholder="" />
                <label class="mb-2 text-muted">Price</label>
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="mb-3 text-muted">
                <label asp-for="ImageFile" class="form-label">Product Image</label>
                <div class="mb-2">
                    <img src="@Model.Imagepath" width="100" />
                </div>
                <input asp-for="ImageFile" type="file" class="form-control" placeholder="" />

            </div>
            <div class="d-flex justify-content-between">
                <div class="col-4">
                    <a asp-action="Index" class="w-100 btn btn-secondary">Back to List</a>
                </div>
                <div class="col-6">
                    <button type="submit" class="w-100 btn btn-dark">Update Product</button>
                </div>
                
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}