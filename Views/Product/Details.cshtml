@model Product


<div class="container">
    <form method="post" asp-action="Details">
        <input type="hidden" name="Productid" value="@Model.Id" />

        <div class="row justify-content-center py-4">
            <div class="col-lg-6 col-md-8">
                <div class="card border-0 shadow border-top border-5 rounded d-flex flex-column">
                    @if (!string.IsNullOrEmpty(Model.Imagepath))
                    {
                        <img src="@Model.Imagepath" class="card-img-top rounded" style="height: 200px;object-fit:cover" />
                    }else
                    {
                        <img src="https://placehold.co/500x600/png" class="card-img-top rounded" />
                    }

                    <div class="card-body d-flex flex-md-column">
                        <p class="card-title text-dark text-uppercase text-center">@Model.Name</p>
                        <p class="text-muted small mb-3">@Model.Description</p>
                    </div>
                    <div class=" card-footer bg-white border-0 text-center">
                        <h6 class="text-dark text-opacity-50">price : @Model.Price</h6>                       
                    </div>
                    <div class="px-2 mb-3 text-secondary small">
                        @Html.Raw(Model.Description)
                    </div>
                    <div class="input-group mb-3 w-50 mx-auto">
                        <span class="input-group-text bg-primary text-white border-0">Qty</span>
                        <input type="number" name="Quantity" value="1" class="form-control text-end"  min="1"/>

                    </div>
                    <div class="mt-auto">
                        <button type="submit" class="btn btn-dark text-uppercase">Add To Cart</button>
                        <a asp-action="Index" class="btn btn-outline-secondary ">Back To Home</a>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>